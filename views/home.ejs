


<!DOCTYPE html>
<html>
<head>
  <title>StumpTalk 🏏</title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <%- include("partials/navbar") %>
    
  <header>
    <h1>🏏 StumpTalk</h1>
    <p>Your Mixed Cricket Diary : Match thoughts, player takes, and memories.</p>

    <a href="/new" class="btn">+ Create New Post</a>
  </header>

  <div style="text-align:center; margin-bottom:20px;">
  <h3>📊 Total Posts: <%= totalPosts %></h3>
  <h4 style="color:gray;">Explore the latest cricket stories from our passionate community</h4>
</div>


  <main>
    <% if (posts.length === 0) { %>
      <p class="empty">No posts yet. Start your first cricket story!</p>
    <% } %>

    <section class="posts-grid">
    <% posts.forEach(post => { %>
      <div class="card">
        <p class="meta">
  <strong><%= post.category %></strong> • <%= new Date(post.created_at).toLocaleDateString() %>
</p>

<p style="font-size:14px; color:gray;">
  ✍️ By <strong><%= post.username %></strong>
</p>

        <h2><%= post.title %></h2>
        <p><%= post.content.substring(0, 120) %>...</p>
        <form action="/like/<%= post.id %>" method="POST">
  <button 
    type="submit" 
    class="like-btn <%= likedPosts.includes(post.id) ? 'liked' : '' %>"
    onclick="animateHeart(this)"
  >
    ❤️ <%= post.likes || 0 %>
  </button>
</form>
        <a href="/post/<%= post.id %>" class="read-btn">
  Read Full Blog →
</a>


      </div>
      
    <% }) %>
    </section>
  </main>
  <%- include("partials/footer") %>
  <script src="/script.js"></script>
</body>
</html>

