<!DOCTYPE html>

<html>
<head>
  <title>Login | StumpTalk</title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>

  <!-- HERO / INTRO SECTION -->

  <section style="text-align:center; padding: 40px 20px;">
    <h1>🏏 StumpTalk</h1>
    <p style="max-width:600px; margin:auto; font-size:16px; line-height:1.5;">
      Welcome to <strong>StumpTalk</strong>.. your personal cricket diary.  
      Share match thoughts, analyze performances, and relive unforgettable cricket moments.
    </p>
  </section>


  <!-- LOGIN FORM -->

  <main>
    <h2 style="text-align:center;">🔐 Login to Continue</h2>


<form action="/login" method="POST" class="form-box">

  <label>Username</label>
  <input type="text" name="username" required>

  <label>Password</label>
  <input type="password" name="password" required>

  <button type="submit" class="btn">Login</button>

</form>

<!-- REGISTER LINK -->
<div style="text-align:center; margin-top:15px;">
  <p>
    New here? 
    <a href="/register" style="color:#ffcc00; font-weight:bold;">
      Create an account
    </a>
  </p>
</div>

<!-- INFO SECTION -->
<div style="text-align:center; margin-top:20px; font-size:14px;">
  <p>📝 Create and manage your own cricket blogs</p>
  <p>🔍 Explore posts with smart filters</p>
  <p>🎮 Play interactive cricket quiz</p>
</div>


  </main>

<%- include("partials/footer") %>

</body>
</html>
