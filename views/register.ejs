<!DOCTYPE html>
<html>
<head>
  <title>Register | StumpTalk</title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>

  <!-- HERO / INTRO -->
  <section class="auth-hero">
    <h1>🏏 StumpTalk</h1>
    <p>
      Join the community. Share your cricket thoughts, memories, and match takes.
    </p>
  </section>

  <!-- REGISTER CARD -->
  <main class="auth-wrapper">

    <div class="auth-card-x9">

      <h2 class="auth-title-x9"> Create Account</h2>

      <form action="/register" method="POST" class="auth-form-x9">

        <label>Username</label>
        <input 
          type="text" 
          name="username" 
          placeholder="Enter username"
          required 
        />

        <label>Password</label>
        <input 
          type="password" 
          name="password" 
          placeholder="Enter password"
          required 
        />

        <button type="submit" class="auth-btn-x9">
          Register
        </button>

      </form>

      <p class="auth-switch-x9">
        Already have an account?
        <a href="/login">Login here</a>
      </p>

    </div>

  </main>

</body>
</html>